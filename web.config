<?xml version="1.0" encoding="utf-8"?>
<!--
  Azure Web App IIS configuration for Node.js (iisnode).
  This file routes all HTTP requests to the Node.js entry point.
-->
<configuration>
  <system.webServer>

    <!-- Route all requests to the Node.js app via iisnode -->
    <handlers>
      <add name="iisnode" path="src/index.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Do not interfere with node-inspector debugging -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^src/index.js\/debug[\/]?" />
        </rule>

        <!-- Route all requests to the Node.js app -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="src/index.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Allow all HTTP response codes to pass through to Node.js -->
    <httpErrors existingResponse="PassThrough" />

    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
